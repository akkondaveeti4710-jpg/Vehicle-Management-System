
def entry():
    x=str(input("Please enter ur vehicle number:"))
    print("Fees for duration amount of time:"
          "\n30 minutes = $5\n"
          "1 hour = $10\n"
          "1 hour and 30 minutes = $15\n"
          "2 hours = $20\n"
          "If u exceed the maximum amount of parking time, there will be an extra fee of $10 to pay")
    y = str(input("Please enter the duration amount of time:"))
    z = str(input("Please enter ur entry time:"))

    vehicle_number = "\nvehicle number =" + x
    duration_time = "\nduration amount of time = " + y
    entry_time = "\nentry time = " + z

    f = open("vehicle_parking.txt", "a")

    f.write(vehicle_number)
    f.write(duration_time)
    f.write(entry_time)

    f.close()

entry()

def exit():
    f=open("vehicle_parking.txt", "a")
    a= str(input("Press 1 if u want to leave or 2 if u want to continue:\n"))
    x = str(input("Please enter ur entry time:"))
    y = str(input("Please enter ur exit time:"))

    if a == "1":
        print("Calculating fee...")
        y = str(input("Please enter the duration amount of time:"))
        if y == "30 minutes":
